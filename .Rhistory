#
##
#
library(lidR)
# Read and add pid
trees <- lidR::readLAS("D:/xxx/lasref/12tree_exampleN.las")
trees <- lidR::add_lasattribute_manual(
trees, 1:nrow(trees@data), "pid", "Point ID",
"int", 0, 1, -1
)
# Select columns and create new LAS
need <- trees@data[, c("X", "Y", "Z", "treeid", "pid")]
new_las <- lidR::LAS(need, lidR::LASheader(need))
# Add extra bytes
new_las <- lidR::add_lasattribute_manual(new_las, need$treeid, "treeid", "Tree ID", "int", 0, 1, -1)
new_las <- lidR::add_lasattribute_manual(new_las, need$pid, "pid", "Point ID", "int", 0, 1, -1)
target_density <- 50  # Adjust this value
trees_decimated <- lidR::decimate_points(new_las, homogenize(target_density, res = 5))
trees_decimated
plot(trees_decimated)
# 4. Save as LAZ (compressed)
dir.create("inst/extdata", recursive = TRUE, showWarnings = FALSE)
lidR::writeLAS(trees_decimated, "inst/extdata/12trees.laz")
new <- readLAS("D:/ahull3D/inst/extdata/12trees.laz")
new@data
devtools::clean_dll()
